# Copy to .env and fill in (never commit .env)
#   cp .env.example .env

# Required for --openai / real extract+embed (mem0-style defaults)
OPENAI_API_KEY=sk-your-key-here

# Optional: Claude as extract LLM (embeddings still need OpenAI unless you change embedder)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Store (self-hosted production) ---
# Local Postgres + pgvector (docker compose up -d in this repo):
# DATABASE_URL=postgresql://mem01:mem01@localhost:5433/mem01
#
# Neon (hosted Postgres + pgvector) — same code path:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#
# Leave unset for local SQLite at data/mem01.db (dev only)
# MEM01_STORE=sqlite
# MEM01_SQLITE_PATH=data/mem01.db
# MEM01_EMBEDDING_DIM=1536

# Optional overrides
# OPENAI_BASE_URL=https://api.openai.com/v1
# MEM01_LLM_MODEL=gpt-4o-mini
# MEM01_EMBED_MODEL=text-embedding-3-small
