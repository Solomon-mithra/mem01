# Copy to .env (never commit .env)
#   cp .env.example .env

# Required for real extract+embed
OPENAI_API_KEY=sk-your-key-here

# Postgres + pgvector (required for real runs — same in docker compose)
# Host machine talking to compose Postgres:
DATABASE_URL=postgresql://mem01:mem01@localhost:5433/mem01
#
# Neon (hosted Postgres + pgvector) — same app code:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

MEM01_EMBEDDING_DIM=1536
# MEM01_LLM_MODEL=gpt-4o-mini
# MEM01_EMBED_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# Unit tests only (no Postgres): MEM01_STORE=memory
